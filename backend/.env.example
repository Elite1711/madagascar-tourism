PORT=5000
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRES_IN=7d

# Connexion PostgreSQL. En local : installe Postgres et crée une base, ou
# utilise un hébergeur gratuit (Supabase, Neon, Render, Railway...) et colle
# l'URL de connexion qu'il te fournit ici.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/madagascar_tourism

# Mettre à true si ton hébergeur exige SSL en local/dev. En production,
# le SSL est activé automatiquement si NODE_ENV=production.
PGSSL=false
